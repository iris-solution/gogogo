# Google Sheets API (Service Account) — dùng để GHI kết quả + KIỂM TRA đã làm bài.
# Lấy từ file JSON key của service account (Google Cloud Console).

# Email của service account, dạng: xxx@yyy.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# Private key (giữ nguyên cả phần BEGIN/END). Dán nguyên văn trong cặp nháy kép,
# các xuống dòng thật hoặc dạng \n đều được — code tự xử lý.
GOOGLE_PRIVATE_KEY=""

# (Tuỳ chọn) ghi đè ID Google Sheet. Mặc định dùng sheet hiện tại.
# SHEET_ID=17-7hAjXUFwTGYtfvyp0dyjoq0M3UZA0E6MNJWqrU-Cg
# SHEET_GID=474156801

# (Tuỳ chọn) tên tab config. Mặc định "config".
# CONFIG_SHEET=config

# === AI chấm câu tự luận (Essay) ===
# Chỉ chạy khi bài test bật cột EnableAI=true trong tab config.
# ĐỪNG dán khoá thật vào file này (nó được commit lên git) — đặt khoá trong
# .env.local (local) và biến môi trường trên Vercel (production).
# Provider: openai | gemini | deepseek  (mặc định openai)
AI_PROVIDER=openai
# Khoá API của provider tương ứng
AI_API_KEY=
# (Tuỳ chọn) ghi đè model. Mặc định: openai=gpt-4o-mini, gemini=gemini-2.5-flash, deepseek=deepseek-chat
AI_MODEL=gpt-5.4-mini
# (Tuỳ chọn) ghi đè base URL (cho provider tự host / tương thích OpenAI khác)
# AI_BASE_URL=
