# Google Sheets API (Service Account) — dùng để GHI kết quả + KIỂM TRA đã làm bài.
# Lấy từ file JSON key của service account (Google Cloud Console).

# Email của service account, dạng: xxx@yyy.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# Private key (giữ nguyên cả phần BEGIN/END). Dán nguyên văn trong cặp nháy kép,
# các xuống dòng thật hoặc dạng \n đều được — code tự xử lý.
GOOGLE_PRIVATE_KEY=""

# (Tuỳ chọn) ghi đè ID Google Sheet. Mặc định dùng sheet hiện tại.
# SHEET_ID=17-7hAjXUFwTGYtfvyp0dyjoq0M3UZA0E6MNJWqrU-Cg
# SHEET_GID=474156801
